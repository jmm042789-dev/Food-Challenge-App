{
  "expo": {
    "name": "Fire Feast",
    "slug": "fire-feast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo/app-icon.png",
    "scheme": "firefeast",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.firefeast.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.firefeast.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo/app-icon.png",
        "backgroundColor": "#070405"
      },
      "edgeToEdgeEnabled": true
    },
    "androidNavigationBar": {
      "backgroundColor": "#070405",
      "barStyle": "light-content"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/backgrounds/splash-screen.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#070405"
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c106538-aa48-4dc2-8100-72fce495be7b"
      }
    },
    "owner": "jmm042789"
  }
}
